    <style name="Widget.Calendar.AddScheduleDropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/add_schedule_field_fill</item>
        <item name="boxStrokeColor">@color/card_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="endIconTint">@color/text_secondary</item>
