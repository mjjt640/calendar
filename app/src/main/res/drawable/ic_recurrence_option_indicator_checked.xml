<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <size
                android:width="18dp"
                android:height="18dp" />
            <solid android:color="@color/calendar_hero" />
            <stroke
                android:width="1dp"
                android:color="@color/calendar_hero" />
        </shape>
    </item>
    <item
        android:width="8dp"
        android:height="8dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="@color/calendar_hero_on" />
        </shape>
    </item>
</layer-list>
