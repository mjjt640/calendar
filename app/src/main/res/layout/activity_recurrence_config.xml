<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_add_schedule_page"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:paddingHorizontal="@dimen/spacing_medium"
        android:paddingTop="@dimen/spacing_small"
        app:navigationIcon="@drawable/ic_calendar_chevron_left"
        app:navigationIconTint="@color/text_secondary"
        app:title="@string/recurrence_config_title"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
        app:titleTextColor="@color/text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="@dimen/spacing_large">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_large"
            android:paddingBottom="@dimen/spacing_large">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_add_schedule_hero"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_large">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tag_chip"
                        android:paddingHorizontal="@dimen/spacing_medium"
                        android:paddingVertical="6dp"
                        android:text="@string/recurrence_config_header_chip"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="@color/calendar_hero" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/recurrence_config_headline"
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="2dp"
                        android:text="@string/recurrence_config_subtitle"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/text_secondary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:background="@drawable/bg_recurrence_summary_panel"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/recurrence_config_summary_label"
                            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                            android:textColor="@color/calendar_hero" />

                        <TextView
                            android:id="@+id/summary_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_add_schedule_stat"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/recurrence_config_frequency_title"
                                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                                android:textColor="@color/calendar_hero" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/recurrence_config_frequency_hint"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_medium"
                            android:layout_weight="1"
                            android:background="@drawable/bg_add_schedule_stat"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/recurrence_config_duration_title"
                                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                                android:textColor="@color/calendar_hero" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/recurrence_config_duration_hint"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                app:cardBackgroundColor="@color/add_schedule_panel_fill"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/recurrence_config_frequency_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/recurrence_config_frequency_hint"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/text_secondary" />

                    <RadioGroup
                        android:id="@+id/frequency_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/frequency_none_option"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_recurrence_option"
                            android:button="@null"
                            android:drawableEnd="@drawable/ic_recurrence_option_indicator"
                            android:drawablePadding="12dp"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="16dp"
                            android:text="@string/recurrence_config_frequency_single"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                            android:textColor="@color/text_primary" />

                        <RadioButton
                            android:id="@+id/frequency_daily_option"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_recurrence_option"
                            android:button="@null"
                            android:drawableEnd="@drawable/ic_recurrence_option_indicator"
                            android:drawablePadding="12dp"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="16dp"
                            android:text="@string/recurrence_config_frequency_daily"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                            android:textColor="@color/text_primary" />

                        <RadioButton
                            android:id="@+id/frequency_weekly_option"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_recurrence_option"
                            android:button="@null"
                            android:drawableEnd="@drawable/ic_recurrence_option_indicator"
                            android:drawablePadding="12dp"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="16dp"
                            android:text="@string/recurrence_config_frequency_weekly"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                            android:textColor="@color/text_primary" />

                        <RadioButton
                            android:id="@+id/frequency_monthly_option"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_recurrence_option"
                            android:button="@null"
                            android:drawableEnd="@drawable/ic_recurrence_option_indicator"
                            android:drawablePadding="12dp"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="16dp"
                            android:text="@string/recurrence_config_frequency_monthly"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                            android:textColor="@color/text_primary" />

                        <RadioButton
                            android:id="@+id/frequency_custom_option"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_recurrence_option"
                            android:button="@null"
                            android:drawableEnd="@drawable/ic_recurrence_option_indicator"
                            android:drawablePadding="12dp"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="16dp"
                            android:text="@string/recurrence_config_frequency_custom"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                            android:textColor="@color/text_primary" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/custom_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:visibility="gone"
                app:cardBackgroundColor="@color/add_schedule_panel_fill"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/recurrence_config_custom_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/recurrence_config_custom_hint"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/text_secondary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/interval_input_layout"
                            style="@style/Widget.Calendar.AddScheduleInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/recurrence_config_custom_interval_hint"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusTopStart="18dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/interval_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:paddingTop="18dp"
                                android:paddingBottom="18dp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/interval_unit_layout"
                            style="@style/Widget.Calendar.AddScheduleDropdown"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_medium"
                            android:layout_weight="1"
                            android:hint="@string/recurrence_config_custom_unit_hint"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusTopStart="18dp">

                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/interval_unit_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:completionThreshold="2147483647"
                                android:cursorVisible="false"
                                android:dropDownHeight="wrap_content"
                                android:dropDownVerticalOffset="10dp"
                                android:focusable="false"
                                android:focusableInTouchMode="false"
                                android:inputType="none"
                                android:longClickable="false"
                                android:paddingTop="18dp"
                                android:paddingBottom="18dp"
                                android:popupBackground="@drawable/bg_priority_dropdown_popup"
                                android:textIsSelectable="false"
                                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/duration_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:visibility="gone"
                app:cardBackgroundColor="@color/add_schedule_panel_fill"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_large">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/recurrence_config_duration_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/recurrence_config_duration_hint"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/text_secondary" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/duration_type_layout"
                        style="@style/Widget.Calendar.AddScheduleDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="@string/recurrence_config_duration_picker_hint"
                        app:boxCornerRadiusBottomEnd="18dp"
                        app:boxCornerRadiusBottomStart="18dp"
                        app:boxCornerRadiusTopEnd="18dp"
                        app:boxCornerRadiusTopStart="18dp">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/duration_type_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:completionThreshold="2147483647"
                            android:cursorVisible="false"
                            android:dropDownHeight="wrap_content"
                            android:dropDownVerticalOffset="10dp"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:inputType="none"
                            android:longClickable="false"
                            android:paddingTop="18dp"
                            android:paddingBottom="18dp"
                            android:popupBackground="@drawable/bg_priority_dropdown_popup"
                            android:textIsSelectable="false"
                            android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:id="@+id/until_date_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_add_schedule_time_panel"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_large"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/recurrence_config_until_label"
                                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/until_date_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_tag_chip"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="@string/recurrence_config_pick_date"
                            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                            android:textColor="@color/calendar_hero" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/until_date_helper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/recurrence_config_until_helper"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="@color/accent_dot"
                        android:visibility="gone" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/occurrence_count_layout"
                        style="@style/Widget.Calendar.AddScheduleInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="@string/recurrence_config_occurrence_hint"
                        android:visibility="gone"
                        app:boxCornerRadiusBottomEnd="18dp"
                        app:boxCornerRadiusBottomStart="18dp"
                        app:boxCornerRadiusTopEnd="18dp"
                        app:boxCornerRadiusTopStart="18dp"
                        app:suffixText="@string/recurrence_config_occurrence_suffix">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/occurrence_count_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:paddingTop="18dp"
                            android:paddingBottom="18dp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_add_schedule_bottom_bar"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_large"
        android:paddingTop="14dp"
        android:paddingBottom="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/recurrence_config_bottom_hint"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/save_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/calendar_hero"
            android:elevation="0dp"
            android:text="@string/recurrence_config_save"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/calendar_hero_on"
            app:cornerRadius="28dp" />
    </LinearLayout>

</LinearLayout>
