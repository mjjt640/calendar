<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_priority_dropdown_item"
    android:gravity="center_vertical"
    android:minHeight="52dp"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/spacing_large"
    android:paddingVertical="12dp">

    <View
        android:id="@+id/priority_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_schedule_card" />

    <TextView
        android:id="@+id/priority_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        android:textColor="@color/text_primary" />

    <ImageView
        android:id="@+id/priority_check"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_priority_check"
        android:tint="@color/calendar_hero"
        android:visibility="gone" />
</LinearLayout>
